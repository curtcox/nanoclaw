+          `Group: ${group.name}`,
+          `Duration: ${duration}ms`,
+          `Exit Code: ${code}`,
+          ``,
+          `=== Stderr ===`,
+          stderr,
+          ``,
+          `=== Stdout ===`,
+          stdout,
+        ].join('\n'),
+      );
+
+      if (code !== 0 && !hadStreamingOutput) {
